---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.replace(/\/$/, "") || "/";

const navLinks = [
  { href: "/inspiration", label: "灵感" },
  { href: "/kb", label: "知识库" },
  { href: "/resume", label: "简历" },
  { href: "/archive", label: "存档" },
];
---

<header class="fixed top-0 left-0 w-full z-50 transition-all duration-700 border-b border-border-muted bg-bg-base/60 backdrop-blur-xl">
  <div class="max-w-[1440px] mx-auto px-6 h-20 md:px-16 flex items-center justify-between">
    <!-- Brand Logo -->
    <a href="/" class="group flex items-center gap-4">
      <div class="w-6 h-[1px] bg-accent/20 group-hover:w-10 group-hover:bg-accent/60 transition-all duration-700"></div>
      <span class="text-[10px] uppercase tracking-[0.6em] font-sans opacity-40 group-hover:opacity-100 group-hover:text-accent transition-all duration-700">
        Whisper
      </span>
    </a>

    <!-- Navigation Links -->
    <nav class="hidden md:flex items-center gap-16">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href || (link.href === '/' && (currentPath === '' || currentPath === '/'));
        return (
          <a 
            href={link.href}
            class={`text-[9px] uppercase tracking-[0.4em] font-sans transition-all duration-700 relative group ${isActive ? 'text-accent opacity-100' : 'text-text-main/60 hover:text-accent hover:opacity-100'}`}
          >
            {link.label}
            <span class={`absolute -bottom-2 left-0 h-[1px] transition-all duration-700 ${isActive ? 'w-full bg-accent/30' : 'w-0 group-hover:w-full group-hover:bg-accent/30'}`}></span>
          </a>
        )
      })}
    </nav>
    
    <!-- Mobile Menu (Minimalist dots) -->
    <button class="md:hidden flex flex-col gap-1.5 p-2 opacity-30 hover:opacity-100 transition-opacity">
        <div class="w-4 h-[1px] bg-text-main"></div>
        <div class="w-3 h-[1px] bg-text-main ml-auto"></div>
    </button>
  </div>
</header>
