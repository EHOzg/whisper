<script is:inline>
  (function() {
    const supportedLangs = ['zh', 'en'];
    const defaultLang = 'zh';
    const path = window.location.pathname;
    
    // Only detect on the root or base paths to avoid redirect loops
    const isRoot = path === '/' || path === '';
    
    if (isRoot) {
      const storedLang = localStorage.getItem('preferred-lang');
      const browserLang = navigator.language.split('-')[0];
      const targetLang = storedLang || (supportedLangs.includes(browserLang) ? browserLang : defaultLang);
      
      if (targetLang !== defaultLang) {
        window.location.pathname = `/${targetLang}${path}`;
      }
    }
  })();
</script>
