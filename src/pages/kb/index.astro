---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { KBGraphView } from '../../components/KB/KBGraphView'
import { getCollection } from 'astro:content'
import { generateGraphData } from '../../utils/kb-graph'

const title = '知识库'
const description = '墨迹在纤维间扩散，思绪在深空里共振。'

const allKB = await getCollection('kb')
const graphData = generateGraphData(allKB)
---

<BaseLayout
  {title}
  {description}
  showFooter={false}
  bodyClass="h-screen overflow-hidden">
  <div class="w-full h-full relative overflow-hidden">
    <KBGraphView client:only="react" data={graphData} />
  </div>
</BaseLayout>
