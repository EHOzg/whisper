---
import "../styles/globals.css";
import Footer from "../components/Navigation/Footer.astro";
import Header from "../components/Navigation/Header.astro";
import LanguageDetector from "../components/Navigation/LanguageDetector.astro";
import { getLangFromUrl } from "../i18n/utils";

interface Props {
	title?: string;
	description?: string;
	showFooter?: boolean;
	showHeader?: boolean;
}

const { 
	title = "Whisper", 
	description = "A quiet container for digital shadows.", 
	showFooter = true,
	showHeader = true 
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<LanguageDetector />

		<!-- Preconnect to fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@100..900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-bg-base text-text-main selection:bg-whisper-glow flex flex-col min-h-screen">
		{showHeader && <Header />}
		<main class={`whisper-fade-in relative z-10 flex-grow w-full ${showHeader ? 'pt-20' : ''}`}>
			<slot />
		</main>
		{showFooter && <Footer />}
	</body>
</html>
