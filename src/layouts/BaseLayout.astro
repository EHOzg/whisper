---
import "../styles/global.css";
import Footer from "../components/Navigation/Footer.astro";
import Header from "../components/Navigation/Header.astro";
import LanguageDetector from "../components/Navigation/LanguageDetector.astro";
import { getLangFromUrl } from "../i18n/utils";

interface Props {
	title?: string;
	description?: string;
	showFooter?: boolean;
	showHeader?: boolean;
}

const { 
	title = "Whisper", 
	description = "A quiet container for digital shadows.", 
	showFooter = true,
	showHeader = true 
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<LanguageDetector />

		<!-- Preconnect to fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@100..900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-bg-base text-text-main selection:bg-accent/15 flex flex-col min-h-screen transition-colors duration-1000">
		<!-- Soft Ambient Background Glows -->
		<div class="fixed inset-0 pointer-events-none z-0 overflow-hidden opacity-20 dark:opacity-10">
			<div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-accent mix-blend-multiply blur-[120px] animate-pulse" style="animation-duration: 8s;"></div>
			<div class="absolute top-[20%] -right-[5%] w-[30%] h-[50%] rounded-full bg-accent-gold mix-blend-multiply blur-[100px] animate-pulse" style="animation-duration: 12s;"></div>
		</div>

		{showHeader && <Header />}
		<main class={`whisper-fade-in relative z-10 flex-grow w-full ${showHeader ? 'pt-20' : ''}`}>
			<slot />
		</main>
		{showFooter && <Footer />}
	</body>
</html>
