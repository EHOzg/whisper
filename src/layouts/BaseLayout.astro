---
import "../styles/global.css";
import Footer from "../components/Navigation/Footer.astro";
import Header from "../components/Navigation/Header.astro";
import SEO from "../components/Common/SEO.astro";
import { FortnightPlayer } from "../components/Common/FortnightPlayer";
import { CommandConsole } from "../components/Navigation/CommandConsole";
import { getCollection } from "astro:content";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	ogType?: 'website' | 'article';
	showFooter?: boolean;
	showHeader?: boolean;
	bodyClass?: string;
	mainClass?: string;
}

const { 
	title, 
	description, 
	image,
	ogType,
	showFooter = true,
	showHeader = true,
	bodyClass = "",
	mainClass = ""
} = Astro.props;

// Fetch and unify search data
const archiveEntries = await getCollection('archive');
const kbEntries = await getCollection('kb');
const inspirationEntries = await getCollection('inspirations');

const searchData = [
  ...archiveEntries.map(e => ({
    id: e.id,
    title: e.data.title,
    description: e.data.description,
    url: `/archive/${e.id.split('/').pop()?.replace(/\.(md|mdx)$/, '')}`,
    type: 'archive' as const
  })),
  ...kbEntries.map(e => ({
    id: e.id,
    title: e.data.title,
    description: e.data.description,
    url: `/kb/${e.id.split('/').pop()?.replace(/\.(md|mdx)$/, '')}`,
    type: 'kb' as const,
    category: e.data.category
  })),
  ...inspirationEntries.map(e => ({
    id: e.id,
    title: '启发碎片',
    description: e.data.content || '',
    url: '/inspiration',
    type: 'inspiration' as const
  }))
];
---

<!doctype html>
<html lang="zh">
	<head>
		<SEO {title} {description} {image} {ogType} />
		
		<!-- Preconnect to fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@100..900&family=Special+Elite&display=swap" rel="stylesheet">
	</head>
	<body class={`bg-bg-base text-text-main selection:bg-accent/15 flex flex-col transition-colors duration-1000 ${bodyClass.includes('overflow-hidden') ? 'h-screen' : 'min-h-screen'} ${bodyClass}`}>
		{bodyClass.includes('overflow-hidden') && <style is:inline>html { overflow: hidden; }</style>}
		<!-- Soft Ambient Background Glows -->
		<div class="fixed inset-0 pointer-events-none z-0 overflow-hidden opacity-20 dark:opacity-10">
			<div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-accent mix-blend-multiply blur-[120px] animate-pulse" style="animation-duration: 8s;"></div>
			<div class="absolute top-[20%] -right-[5%] w-[30%] h-[50%] rounded-full bg-accent-gold mix-blend-multiply blur-[100px] animate-pulse" style="animation-duration: 12s;"></div>
		</div>

		{showHeader && <Header />}
		<main class={`relative z-10 w-full ${bodyClass.includes('overflow-hidden') ? 'h-full' : 'flex-grow'} ${showHeader ? 'pt-[var(--nav-height)]' : ''} ${mainClass}`}>
			<slot />
		</main>
		{showFooter && <Footer />}
		<CommandConsole client:only="react" data={searchData} />
		<FortnightPlayer client:load />
	</body>
</html>
