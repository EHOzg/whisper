---
import { SocialLinks, ContactLink } from "./components/SocialLinks";

const currentData = [
  {
    period: "2024 — 至今",
    title: "静谧架构",
    company: "个人理想实践",
    monologue: "在沉默中建造。我发现那些最响亮的声音往往言之无物。Project Whisper 是我归回数字工艺核心的一次尝试——在这里，性能是被感知的，而不仅仅是被测量的；美学是通向专注的门户。",
    details: ["Astro", "React Islands", "设计系统", "动效编排"]
  },
  {
    period: "2021 — 2023",
    title: "首席视觉工程师",
    company: "Aether Dynamics",
    monologue: "从代码到画布的过渡是天衣无缝的。我们不仅仅是在构建界面，而是在编排数字体验。我意识到，300 毫秒的过渡不仅仅是物理上的延迟，更是连接意图与行动的心理桥梁。",
    details: ["创意代码", "WebGL", "前端架构", "团队导师"]
  },
  {
    period: "2018 — 2021",
    title: "界面设计师",
    company: "Origin Studio",
    monologue: "最初，只有留白。我花了三年时间去理解像素的重量和排版的引力。就在那时，我意识到设计不是你增加了什么，而是你是否有勇气移除什么。",
    details: ["UI/UX 设计", "原型设计", "设计工程"]
  },
  {
    period: "早些时候",
    title: "觉醒",
    company: "自主探索",
    monologue: "每个故事都有序曲。我的序曲始于对逻辑如何具象化为美的好奇。我写下的第一行代码就像在黑暗房间里的一声耳语——微弱，但充满了可能性。",
    details: ["计算机科学基础", "艺术探索"]
  }
];
---

<div class="max-w-4xl mx-auto px-6 py-32 md:py-48">
  <!-- Header -->
  <div class="mb-32 space-y-6">
    <h1 class="text-4xl md:text-6xl tracking-tight leading-tight max-w-2xl whisper-fade-in" style="animation-delay: 100ms;">
      成长历程
    </h1>
    <p class="text-accent text-sm md:text-base max-w-md leading-relaxed whisper-fade-in" style="animation-delay: 300ms;">
      不止于一份简历，更是一段关于好奇心与手艺的叙事。
    </p>
  </div>

  <!-- Timeline -->
  <div class="relative">
    <!-- Vertical Line -->
    <div class="absolute left-0 md:left-1/4 top-0 bottom-0 w-[1px] bg-text-main/5 pointer-events-none"></div>

    <div class="space-y-24 md:space-y-32">
      {currentData.map((item, index) => (
        <div class="relative flex flex-col md:flex-row group whisper-fade-in" style={`animation-delay: ${500 + index * 200}ms;`}>
          <!-- Period (Desktop) -->
          <div class="hidden md:block w-1/4 pr-12 text-right">
            <span class="text-[10px] uppercase tracking-[0.3em] text-accent opacity-50 group-hover:opacity-100 transition-opacity duration-700 font-sans">
              {item.period}
            </span>
          </div>

          <!-- Timeline Dot -->
          <div class="absolute left-[-4px] md:left-[calc(25%-4px)] top-2 w-2 h-2 rounded-full border border-text-main/10 bg-bg-base group-hover:scale-150 group-hover:border-text-main/30 group-hover:bg-text-main transition-all duration-700 z-10"></div>

          <!-- Content -->
          <div class="pl-8 md:pl-16 flex-1">
            <!-- Period (Mobile) -->
            <div class="md:hidden mb-4">
              <span class="text-[9px] uppercase tracking-[0.3em] text-accent opacity-60 font-sans">
                {item.period}
              </span>
            </div>

            <div class="space-y-4">
              <div class="flex flex-col gap-1">
                <h3 class="text-xl md:text-2xl tracking-normal">{item.title}</h3>
                <span class="text-[10px] uppercase tracking-[0.2em] text-accent font-sans">{item.company}</span>
              </div>
              
              <p class="text-base md:text-lg leading-relaxed text-text-main/80 font-serif max-w-2xl italic">
                "{item.monologue}"
              </p>

              <div class="flex flex-wrap gap-x-6 gap-y-2 pt-4">
                {item.details.map((detail) => (
                  <span class="text-[9px] uppercase tracking-[0.15em] text-accent/60 font-sans">
                    {detail}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Perspective Section -->
  <div class="mt-48 md:mt-64 pt-32 border-t border-text-main/5 whisper-fade-in" style="animation-delay: 1500ms;">
    <div class="max-w-2xl">
      <div class="space-y-6">
        <h2 class="text-2xl md:text-3xl">设计哲学</h2>
        <p class="text-accent text-sm md:text-base leading-relaxed">
          我相信技术应当是无形的——它是在追求以人为本目标时的静默伙伴。我的工作遵循“负空间”原则，确保每一次增加都有其意义。
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  /* Custom easing for group interactions */
  .group {
    transition: transform 0.7s var(--ease-whisper);
  }
</style>
