---
import { SocialLinks, ContactLink } from "./components/SocialLinks";

const currentData = [
  {
    period: "2023.12 — 至今",
    title: "核心开发者 / 创始人",
    company: "Project Whisper",
    monologue: "重新定义个人数字空间。在 Project Whisper 中，我实验了极致的排版与交互逻辑。代码不再是冰冷的逻辑，而是流动的诗意。我们追求的是一种‘数字静谧’，让用户在喧嚣的项目中找到专注的出口。",
    details: ["Astro 6.1", "Tailwind 4.0", "Framer Motion", "GLSL"]
  },
  {
    period: "2021.05 — 2023.11",
    title: "资深前端工程师",
    company: "赛博飞跃 (Cyber Leap)",
    monologue: "负责高性能 Web 应用的架构设计。通过引入 WebGL 渲染管线，我们将视觉表现力提升到了新的维度，同时保持了极佳的加载速度。我主导了核心组件库的重构，并成功推动了团队向现代响应式架构的转型。",
    details: ["Three.js", "WebGL", "性能优化", "架构设计"]
  },
  {
    period: "2018.07 — 2021.04",
    title: "视觉前端开发",
    company: "创意工坊 (Creative Workshop)",
    monologue: "在这里，我学会了如何让像素呼吸。每一场交互都是一场对话。从 1:1 还原设计稿到探索动态界面的可能性，我致力于打破设计与开发之间的界限，创造令人心动的交互体验。",
    details: ["UI/UX", "SVG 动画", "交互设计", "跨平台协作"]
  }
];
---

<div class="max-w-4xl mx-auto px-6 py-32 md:py-48">
  <!-- Timeline -->
  <div class="relative">
    <!-- Vertical Line -->
    <div class="absolute left-0 md:left-1/4 top-0 bottom-0 w-[1px] bg-text-main/5 pointer-events-none"></div>

    <div class="space-y-24 md:space-y-32">
      {currentData.map((item, index) => (
        <div class="relative flex flex-col md:flex-row group whisper-fade-in" style={`animation-delay: ${600 + index * 200}ms;`}>
          <!-- Period (Desktop) -->
          <div class="hidden md:block w-1/4 pr-12 text-right">
            <span class="text-[10px] uppercase tracking-[0.3em] text-accent opacity-50 group-hover:opacity-100 transition-opacity duration-700 font-sans">
              {item.period}
            </span>
          </div>

          <!-- Timeline Dot -->
          <div class="absolute left-[-4px] md:left-[calc(25%-4px)] top-2 w-2 h-2 rounded-full border border-text-main/10 bg-bg-base group-hover:scale-150 group-hover:border-text-main/30 group-hover:bg-text-main transition-all duration-700 z-10"></div>

          <!-- Content -->
          <div class="pl-8 md:pl-16 flex-1">
            <!-- Period (Mobile) -->
            <div class="md:hidden mb-4">
              <span class="text-[9px] uppercase tracking-[0.3em] text-accent opacity-60 font-sans">
                {item.period}
              </span>
            </div>

            <div class="space-y-4">
              <div class="flex flex-col gap-1">
                <h3 class="text-xl md:text-2xl tracking-normal">{item.title}</h3>
                <span class="text-[10px] uppercase tracking-[0.2em] text-accent font-sans">{item.company}</span>
              </div>
              
              <p class="text-base md:text-lg leading-relaxed text-text-main/80 font-serif max-w-2xl italic">
                "{item.monologue}"
              </p>

              <div class="flex flex-wrap gap-x-6 gap-y-2 pt-4">
                {item.details.map((detail) => (
                  <span class="text-[9px] uppercase tracking-[0.15em] text-accent/60 font-sans">
                    {detail}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Skills Section -->
  <div class="mt-48 md:mt-64 whisper-fade-in" style="animation-delay: 1300ms;">
    <h2 class="text-2xl md:text-3xl mb-16 tracking-tight">技术栈</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16">
      <div class="space-y-6">
        <h4 class="text-[10px] uppercase tracking-[0.3em] text-accent">前端开发</h4>
        <div class="space-y-3">
          <p class="text-lg font-serif italic text-text-main/80">React 19 / Next.js / Astro 6.1</p>
          <p class="text-xs text-text-main/40 leading-relaxed uppercase tracking-widest">
            擅长构建响应式、高性能的现代化 Web 应用，深谙内容层架构设计。
          </p>
        </div>
      </div>
      <div class="space-y-6">
        <h4 class="text-[10px] uppercase tracking-[0.3em] text-accent">视觉动效</h4>
        <div class="space-y-3">
          <p class="text-lg font-serif italic text-text-main/80">Three.js / GLSL / Framer Motion</p>
          <p class="text-xs text-text-main/40 leading-relaxed uppercase tracking-widest">
            探索 WebGL 的无限可能，致力于将物理动效与叙事逻辑完美结合。
          </p>
        </div>
      </div>
      <div class="space-y-6">
        <h4 class="text-[10px] uppercase tracking-[0.3em] text-accent">工程设计</h4>
        <div class="space-y-3">
          <p class="text-lg font-serif italic text-text-main/80">Tailwind 4.0 / Figma / Design System</p>
          <p class="text-xs text-text-main/40 leading-relaxed uppercase tracking-widest">
            从像素单位到色彩协议，构建严谨且具备美感的设计系统。
          </p>
        </div>
      </div>
    </div>
  </div>

</div>

<style>
  /* Custom easing for group interactions */
  .group {
    transition: transform 0.7s var(--ease-whisper);
  }
</style>
